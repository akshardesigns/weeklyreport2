From bea3f2f417d362be378c4553a6187eb1736788d8 Mon Sep 17 00:00:00 2001
From: Claude <claude@local>
Date: Tue, 21 Jul 2026 17:46:06 +0000
Subject: [PATCH] Double-klik sel kalender untuk tambah brief baru dengan
 tanggal posting terisi otomatis

---
 pages/index.js     | 11 ++++++++---
 styles/globals.css |  2 +-
 2 files changed, 9 insertions(+), 4 deletions(-)

diff --git a/pages/index.js b/pages/index.js
index 5339459..a524895 100644
--- a/pages/index.js
+++ b/pages/index.js
@@ -254,9 +254,9 @@ export default function Home() {
   }, [filteredBriefs, filterPilar, filterPlatform, filterStatus]);
   const hasTableFilter = filterPilar || filterPlatform || filterStatus;
 
-  function openAddForm() {
+  function openAddForm(prefill) {
     setEditingId(null);
-    setForm(EMPTY_FORM);
+    setForm(prefill ? { ...EMPTY_FORM, ...prefill } : EMPTY_FORM);
     setFormMsg('');
     setUploadedFileName('');
     setFormOpen(true);
@@ -579,6 +579,8 @@ export default function Home() {
                 <div
                   key={cell.iso}
                   className={`calendar-cell${cell.inMonth ? '' : ' is-outside'}${cell.iso === today ? ' is-today' : ''}`}
+                  onDoubleClick={() => openAddForm({ tglPosting: cell.iso })}
+                  title="Klik dua kali untuk tambah brief di tanggal ini"
                 >
                   <div className="calendar-cell-date">{cell.date.getDate()}</div>
                   <div className="calendar-cell-items">
@@ -589,7 +591,10 @@ export default function Home() {
                           key={b.id}
                           className="calendar-item"
                           style={{ background: style.bg, borderLeftColor: style.border }}
-                          onClick={() => enterEditMode(b.id)}
+                          onClick={(e) => {
+                            e.stopPropagation();
+                            enterEditMode(b.id);
+                          }}
                           title={`${platformLabel(b)} · ${b.pilar} · ${b.brief} — ${statusOf(b)}`}
                         >
                           <div className="calendar-item-platform">{platformLabel(b)} · {b.pilar}</div>
diff --git a/styles/globals.css b/styles/globals.css
index 82b7e7b..cc0d5f3 100644
--- a/styles/globals.css
+++ b/styles/globals.css
@@ -208,7 +208,7 @@ tbody tr.is-editing{background:rgba(0,113,227,0.06);}
 
 .calendar-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:8px;}
 .calendar-dow{font-size:12px;font-weight:600;color:var(--sub);text-align:center;padding-bottom:6px;}
-.calendar-cell{background:var(--card);border-radius:14px;min-height:110px;padding:8px;box-shadow:0 1px 2px rgba(0,0,0,0.04);display:flex;flex-direction:column;gap:4px;}
+.calendar-cell{background:var(--card);border-radius:14px;min-height:110px;padding:8px;box-shadow:0 1px 2px rgba(0,0,0,0.04);display:flex;flex-direction:column;gap:4px;cursor:pointer;}
 .calendar-cell.is-outside{background:transparent;box-shadow:none;opacity:.4;}
 .calendar-cell.is-today{outline:2px solid var(--blue);outline-offset:-2px;}
 .calendar-cell-date{font-size:12.5px;font-weight:700;color:var(--sub);}
-- 
2.43.0

